# ─────────────────────────────────────────────────────────────────
#  KROK 1: Zkopíruj tento soubor jako .env.local
#          (v terminálu: cp .env.local.example .env.local)
#
#  KROK 2: Doplň hodnoty z Firebase konzole:
#          console.firebase.google.com
#          → Nastavení projektu → Tvoje aplikace → Konfigurace SDK
# ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────────
#  POZNÁMKA K DOMÉNÁM:
#  Povolené domény jsou definovány přímo v kódu v souboru:
#    lib/types.ts  →  konstanta ALLOWED_DOMAINS
#
#  Aktuálně povolené domény:
#    euroinstitut.cz  →  organizace Euroinstitut
#    eduservis.cz     →  organizace Eduservis    ← uprav příponu pokud jiná
#    biotherapy.cz    →  organizace Biotherapy   ← uprav příponu pokud jiná
# ─────────────────────────────────────────────────────────────────
